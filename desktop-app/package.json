{
  "name": "wodnecustomy-desktop",
  "version": "1.0.0",
  "description": "Lokalna apka do zbierania danych z customowych gier 5v5 League of Legends (LCU) i synchronizacji z Google Sheets.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.wodnecustomy.desktop",
    "productName": "WodneCustomy",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
